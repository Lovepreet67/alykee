  "query": "\n            SELECT\n                id,\n                title,\n                description,\n                status as \"status: TaskStatus\",\n                priority,\n                created_by_id,\n                assigned_to_id,\n                created_at,\n                updated_at\n            FROM task\n            WHERE assigned_to_id = $1\n            ORDER BY created_at DESC\n            ",
