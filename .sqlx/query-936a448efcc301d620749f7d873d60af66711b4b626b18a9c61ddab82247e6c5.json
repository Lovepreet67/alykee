  "query": "\n            INSERT INTO task (\n                title,\n                description,\n                status,\n                priority,\n                created_by_id,\n                assigned_to_id\n            )\n            VALUES (\n                $1,\n                $2,\n                'todo'::task_status,\n                $3,\n                $4,\n                $5\n            )\n            RETURNING\n                id,\n                title,\n                description,\n                status as \"status: TaskStatus\",\n                priority,\n                created_by_id,\n                assigned_to_id,\n                created_at,\n                updated_at\n            ",
